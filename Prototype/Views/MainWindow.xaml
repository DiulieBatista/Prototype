<Window x:Class="PrototypeCorpoHumano.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Multiplicação Celular" Height="350" Width="400">

    <StackPanel Margin="20">

        <TextBlock Text="Simulação de Multiplicação Celular"
                   FontSize="20"
                   Margin="0 0 0 20"/>

        <Button Content="Clonar Célula"
                Height="40"
                Click="Clonar_Click"/>

        <ListBox Name="ListaCelulas"
                 Margin="0 20 0 0"/>

    </StackPanel>

</Window>